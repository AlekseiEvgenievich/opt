/control/verbose 1
/run/verbose 1
/event/verbose 0
/tracking/verbose 0

/run/initialize

/gps/particle proton
/gps/ene/type Mono
/gps/ene/mono 1 MeV

/gps/pos/type Volume
/gps/pos/shape Para
/gps/pos/centre 0 0 0 cm
/gps/pos/halfx 1.5 cm
/gps/pos/halfy 1.25 cm
/gps/pos/halfz 1.25 cm

/gps/ang/type iso

/run/beamOn 1000